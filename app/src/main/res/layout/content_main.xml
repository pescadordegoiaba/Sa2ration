<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat"
            android:text="@string/preview"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:contentDescription="@string/preview"
            android:elevation="8dp"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/test_img" />

        <TextView
            style="@style/ColorSectionTitle"
            android:text="@string/global_adjustments" />

        <TextView
            android:id="@+id/saturationLabel"
            style="@style/ColorControlLabel"
            android:labelFor="@id/saturationInput"
            android:text="@string/saturation_level" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/saturationSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/saturationInput"
                style="@style/ColorControlInput"
                android:imeOptions="actionDone" />
        </LinearLayout>

        <TextView
            android:id="@+id/contrastLabel"
            style="@style/ColorControlLabel"
            android:labelFor="@id/contrastInput"
            android:text="@string/contrast_level" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/contrastSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/contrastInput"
                style="@style/ColorControlInput"
                android:imeOptions="actionDone" />
        </LinearLayout>

        <TextView
            style="@style/ColorSectionTitle"
            android:layout_marginTop="8dp"
            android:text="@string/saturation_by_color" />

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/redSaturationInput"
            android:text="@string/red" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/redSaturationSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/redSaturationInput"
                style="@style/ColorControlInput" />
        </LinearLayout>

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/greenSaturationInput"
            android:text="@string/green" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/greenSaturationSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/greenSaturationInput"
                style="@style/ColorControlInput" />
        </LinearLayout>

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/blueSaturationInput"
            android:text="@string/blue" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/blueSaturationSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/blueSaturationInput"
                style="@style/ColorControlInput" />
        </LinearLayout>

        <TextView
            style="@style/ColorSectionTitle"
            android:layout_marginTop="8dp"
            android:text="@string/contrast_by_color" />

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/redContrastInput"
            android:text="@string/red" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/redContrastSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/redContrastInput"
                style="@style/ColorControlInput" />
        </LinearLayout>

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/greenContrastInput"
            android:text="@string/green" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/greenContrastSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/greenContrastInput"
                style="@style/ColorControlInput" />
        </LinearLayout>

        <TextView
            style="@style/ColorControlLabel"
            android:labelFor="@id/blueContrastInput"
            android:text="@string/blue" />

        <LinearLayout style="@style/ColorControlRow">

            <SeekBar
                android:id="@+id/blueContrastSeekBar"
                style="@style/ColorControlSeekBar" />

            <EditText
                android:id="@+id/blueContrastInput"
                style="@style/ColorControlInput"
                android:imeOptions="actionDone" />
        </LinearLayout>

        <TextView
            style="@style/ColorSectionTitle"
            android:layout_marginTop="8dp"
            android:text="@string/color_management" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/dci"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/enable_dci"
            android:textSize="14sp" />

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/reset"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reset" />

            <Button
                android:id="@+id/apply"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
