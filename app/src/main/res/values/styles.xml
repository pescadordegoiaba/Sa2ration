<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sa_primary</item>
        <item name="colorOnPrimary">@color/sa_on_primary</item>
        <item name="colorPrimaryContainer">@color/sa_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/sa_on_primary_container</item>
        <item name="colorSecondary">@color/sa_secondary</item>
        <item name="colorSecondaryContainer">@color/sa_secondary_container</item>
        <item name="colorSurface">@color/sa_surface</item>
        <item name="colorSurfaceContainer">@color/sa_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/sa_surface_container_high</item>
        <item name="colorOnSurface">@color/sa_on_surface</item>
        <item name="colorOutline">@color/sa_outline</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="materialAlertDialogTheme">@style/Sa2ration.AlertDialog</item>
    </style>

    <style name="Sa2ration.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/Sa2ration.Shape.Dialog</item>
    </style>

    <style name="Sa2ration.Shape.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="Sa2ration.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="titleTextAppearance">@style/TextAppearance.Material3.TitleLarge</item>
    </style>

</resources>
